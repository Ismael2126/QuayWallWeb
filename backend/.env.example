# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=quaywall
DB_USER=quaywall_user
DB_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_chars_here_change_me
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=quaywall@example.com
MAIL_FROM_NAME=Quay Wall System

# SMS Configuration
SMS_API_URL=https://api.msgowl.com/api/v2/sms/send
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_ID=QuayWall

# Application Configuration
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080

# Session Configuration
SESSION_LIFETIME=1800
REMEMBER_ME_LIFETIME=604800

# Redis (optional, for rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379